# Copy to `.env` and fill in. Everything here is OPTIONAL except the SEC contact.
# Free/official-API posture: only SEC strictly requires a contact string.

# --- SEC EDGAR (required by SEC fair-access policy: a real contact) ---
# SEC asks every automated client to identify itself with a contact email.
ALTSIGNAL_CONTACT_EMAIL=you@example.com
# Optional full override of the User-Agent string sent to SEC:
# ALTSIGNAL_SEC_USER_AGENT=altsignal/0.1 (you@example.com)

# --- Optional connectors (left blank = connector reports itself unavailable) ---
# FRED macro data: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Reddit API (script app): https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=altsignal/0.1 by u/yourname

# --- Behavior ---
# Default cache TTL for raw HTTP responses, in seconds (default 86400 = 1 day).
ALTSIGNAL_CACHE_TTL=86400
# Where the SQLite cache/store lives (default: data/altsignal.sqlite under project root).
# ALTSIGNAL_DB_PATH=
